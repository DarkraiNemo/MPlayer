{
  "name": "mplayer",
  "version": "1.0.1",
  "description": "Mplayer Built In Electron, provinding the User to listen to songs.",
  "homepage": "https://github.com/DarkraiNemo/MPlayer.git",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.mplayer.mplayer",
    "productName": "MPlayer",
    "icon": "./srcs/MPlayer.svg",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Darkgrey_ <backupusa190@gmail.com>",
      "icon": "./srcs/MPlayer.svg"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "./srcs/MPlayer.svg"
    }
  },
  "license": "ISC",
  "author": "Darkgrey_ <backupusa190@gmail.com>",
  "type": "commonjs",
  "main": "main.js",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
